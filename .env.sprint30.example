# Sprint 30 — configuração mínima para batch de validação
# Uso: cp .env.sprint30.example .env  (ou merge manual no .env existente)

# --- Feature flags Sprint 30 ---
SPRINT30=true
FOOTAGE_FIRST=true
RETENTION_CONTROLLER=true
SPRINT30_METRICS_PATH=database/sprint_30_metrics.jsonl

# --- Obrigatório ---
GEMINI_API_KEY=
PEXELS_API_KEY=

# --- IA fallback (se Gemini falhar ou quota esgotada) ---
GROQ_API_KEY=
OPENROUTER_API_KEY=

# --- TTS premium (opcional — sem isso usa Edge TTS gratuito) ---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# --- Stock fallback (opcional se Pexels indisponível) ---
PIXABAY_API_KEY=

# --- Pipeline ---
DEFAULT_PLATFORM=youtube_dark
CONTENT_MODE=stock
MAX_T2V_SCENES_PER_VIDEO=2

# --- Upload (desligado na validação Sprint 30) ---
YOUTUBE_AUTO_UPLOAD=false
YOUTUBE_DRY_RUN=true
