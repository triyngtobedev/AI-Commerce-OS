# Sprint 30 — variáveis mínimas para o batch rodar
# Uso: cp .env.sprint30.example .env   (Railway: aba Variables)
#
# Checklist:
#   1. Preencher OBRIGATÓRIAS abaixo (sem comentários inline na mesma linha)
#   2. python3 -c "from scripts.ai.router import get_client; print(get_client().health())"
#   3. python3 scripts/run_sprint_30_batch.py --max-videos 2   (~15 min, valida config)
#   4. Se OK: python3 scripts/run_sprint_30_batch.py --max-videos 8
#   5. Coletar sprint_30_metrics.jsonl + docs/sprint_30_report.md

# === OBRIGATÓRIAS (batch falha sem elas) ===

# IA texto (router: Groq → OpenRouter). Precisa de pelo menos 1.
# primário — https://console.groq.com/keys
GROQ_API_KEY=
# fallback — https://openrouter.ai/keys
OPENROUTER_API_KEY=
# fallback pontual (thumbnail A/B, persona, visual) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Footage (PR #29 footage-first). Precisa de pelo menos Pexels.
# https://www.pexels.com/api/
PEXELS_API_KEY=
# opcional — https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# TTS (narração) — pipeline atual: Azure → Edge → gTTS (fallback gratuito)
# Batch completa com Azure (melhor qualidade) OU só Edge/gTTS (sem chave).
# https://portal.azure.com — recomendado
AZURE_SPEECH_KEY=
# ex: eastus, brazilsouth
AZURE_SPEECH_REGION=

# ElevenLabs NÃO está integrado nesta sprint (Sprint 31+).
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# === FEATURE FLAGS SPRINT 30 (default = on, exceto thumbnail A/B) ===
SPRINT30_ENABLED=true
SPRINT30_VISUAL_SCORE=true
SPRINT30_THUMBNAIL_AB=false
SPRINT30_AUDIO_LAYER=true
SPRINT30_RETENTION=true
SPRINT30_RETENTION_CONTROLLER=true
SPRINT30_METRICS=true

# === OPCIONAIS ===
# Upload YouTube (OAuth — ver docs/youtube_oauth.md)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_AUTO_UPLOAD=false

# Visual score (Gemini multimodal — desempate editorial, free tier)
VISUAL_SCORE_TOP_N=2
# VISUAL_SCORE_MODEL=gemini-2.0-flash-lite
# THUMBNAIL_IMAGE_MODEL=gemini-2.5-flash-image
