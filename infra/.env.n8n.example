# =============================================================================
# Configuração do n8n — copie para infra/.env.n8n e preencha os valores
# Este arquivo é SEPARADO do .env principal do projeto Python
# =============================================================================
#
# --- Setup LOCAL (sem domínio, R$ 0) ---
#   cd infra
#   copy .env.n8n.example .env.n8n
#   docker compose -f docker-compose.local.yml up -d
#   Acesse: http://localhost:5678
#
#   Use estes valores para localhost:
#     N8N_HOST=localhost
#     WEBHOOK_URL=http://localhost:5678/
#
# --- Setup PRODUÇÃO (VM + domínio) ---
#   docker compose up -d   (usa docker-compose.yml + nginx + SSL)
#
# =============================================================================

# --- Domínio público (produção) ou localhost (local) ---
N8N_HOST=n8n.seudominio.com

# URL base para webhooks gerados pelo n8n
# Local: http://localhost:5678/  |  Produção: https://n8n.seudominio.com/
WEBHOOK_URL=https://n8n.seudominio.com/

# --- Autenticação básica do painel n8n ---
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=altere_esta_senha_forte

# --- Fuso horário ---
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo

# --- Chave de criptografia (obrigatória em produção) ---
# Gere com: openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# --- Execuções ---
# Mantém histórico de execuções por 168h (7 dias)
EXECUTIONS_DATA_SAVE_ON_SUCCESS=all
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_MAX_AGE=168

# --- Webhook secret (validação HMAC opcional nos workflows) ---
# Deve coincidir com N8N_WEBHOOK_SECRET no .env principal do Python
N8N_WEBHOOK_SECRET=

# --- URL da API do pipeline (usada pelos workflows n8n) ---
# Local (FastAPI no PC):  http://host.docker.internal:8000
# Railway (nuvem):        https://SUA-URL.up.railway.app
# Preenchido automaticamente por infra/ativar-n8n.ps1
PIPELINE_API_BASE_URL=

# Chave X-API-Key — mesma PIPELINE_API_KEY do Railway (Variables)
# Preenchida automaticamente por infra/ativar-n8n.ps1
PIPELINE_API_KEY=

# --- Email (opcional — notificações de erro) ---
# N8N_EMAIL_MODE=smtp
# N8N_SMTP_HOST=smtp.gmail.com
# N8N_SMTP_PORT=587
# N8N_SMTP_USER=
# N8N_SMTP_PASS=
# N8N_SMTP_SENDER=
