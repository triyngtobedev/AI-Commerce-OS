        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"scene_id\": \"{{ $('Set — Normalizar Payload').item.json.scene_id }}\",\n  \"job_id\": \"{{ $('Set — Normalizar Payload').item.json.job_id }}\",\n  \"video_path\": null,\n  \"provider_used\": null,\n  \"status\": \"failed\",\n  \"error_message\": \"All free providers failed (Replicate, HF Router). Python may retry Kling Web locally.\"\n}",
        "options": {}
