            {
              "id": "video_path",
              "name": "video_path",
              "value": "={{ Array.isArray($json.output) ? $json.output[0] : ($json.output || '') }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "set-replicate-result",
      "name": "Set — Resultado Replicate",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1680, 360]
