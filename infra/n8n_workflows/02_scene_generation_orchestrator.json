    {
      "parameters": {
        "method": "POST",
        "url": "https://router.huggingface.co/fal-ai/fal-ai/wan/v2.2-5b/text-to-video",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"prompt\": {{ JSON.stringify($('Set — Normalizar Payload').item.json.prompt) }},\n  \"num_frames\": 49,\n  \"aspect_ratio\": {{ JSON.stringify($('Set — Normalizar Payload').item.json.aspect_ratio) }}\n}",
        "options": {
          "timeout": 300000,
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "http-hf-t2v",
      "name": "HTTP — HF Router T2V",
