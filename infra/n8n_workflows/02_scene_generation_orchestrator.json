        "specifyBody": "json",
        "jsonBody": "={\n  \"scene_id\": \"{{ $('Set — Normalizar Payload').item.json.scene_id }}\",\n  \"job_id\": \"{{ $('Set — Normalizar Payload').item.json.job_id }}\",\n  \"video_path\": \"{{ $json.video_path }}\",\n  \"provider_used\": \"{{ $json.provider_used }}\",\n  \"status\": \"completed\"\n}",
        "options": {}
      },
      "id": "http-callback-success",
      "name": "Callback — Sucesso",
      "type": "n8n-nodes-base.httpRequest",
