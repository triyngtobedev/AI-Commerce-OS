          "id": "HF_CREDENTIAL_ID",
          "name": "Hugging Face API Token"
        }
      },
      "notes": "Fallback free HF Router (fal.ai Wan2.2). Crédito mensal limitado."
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "hf-url",
              "leftValue": "={{ $json.video?.url || $json.url || $json.output?.video?.url || (Array.isArray($json.output) ? $json.output[0] : $json.output) || '' }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
