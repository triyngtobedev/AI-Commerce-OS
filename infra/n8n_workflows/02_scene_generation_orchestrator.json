          "assignments": [
            {
              "id": "provider",
              "name": "provider_used",
              "value": "falai_hf",
              "type": "string"
            },
            {
              "id": "video_path",
              "name": "video_path",
              "value": "={{ $json.video?.url || $json.url || $json.output?.video?.url || (Array.isArray($json.output) ? $json.output[0] : $json.output) }}",
