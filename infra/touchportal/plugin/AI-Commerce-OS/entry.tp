{
  "api": 12,
  "version": 1,
  "name": "AI-Commerce-OS",
  "id": "com.triyn.aicommerceos",
  "configuration": {
    "colorDark": "#FFB703",
    "colorLight": "#0C1220",
    "parentCategory": "tools"
  },
  "categories": [
    {
      "id": "com.triyn.aicommerceos.main",
      "name": "AI-Commerce-OS",
      "actions": [
        {
          "id": "acmd_pipeline_ia",
          "name": "Pipeline IA (tema automatico)",
          "prefix": "AI-Commerce",
          "type": "execute",
          "lines": {
            "action": [
              {
                "language": "default",
                "data": [
                  { "lineFormat": "Pipeline IA — nuvem/research" }
                ]
              }
            ]
          },
          "execution_cmd": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"%TP_PLUGIN_FOLDER%aicommerce.ps1\" -Action pipeline-ia",
          "data": []
        },
        {
          "id": "acmd_pipeline_tema",
          "name": "Pipeline Tema",
          "prefix": "AI-Commerce",
          "type": "execute",
          "lines": {
            "action": [
              {
                "language": "default",
                "data": [
                  { "lineFormat": "Pipeline tema: {$topic$}" }
                ]
              }
            ]
          },
          "execution_cmd": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"%TP_PLUGIN_FOLDER%aicommerce.ps1\" -Action pipeline-tema -Topic \"{$topic$}\"",
          "data": [
            {
              "id": "topic",
              "type": "text",
              "label": "Tema do video",
              "default": "A verdade sobre a Biblioteca de Alexandria"
            }
          ]
        },
        {
          "id": "acmd_pipeline_rerun",
          "name": "Pipeline Rerun",
          "prefix": "AI-Commerce",
          "type": "execute",
          "lines": {
            "action": [
              {
                "language": "default",
                "data": [
                  { "lineFormat": "Rerun pipeline (--force)" }
                ]
              }
            ]
          },
          "execution_cmd": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"%TP_PLUGIN_FOLDER%aicommerce.ps1\" -Action pipeline-rerun",
          "data": []
        },
        {
          "id": "acmd_last_video",
          "name": "Ultimo video",
          "prefix": "AI-Commerce",
          "type": "execute",
          "lines": {
            "action": [
              {
                "language": "default",
                "data": [
                  { "lineFormat": "Abrir ultimo video_final.mp4" }
                ]
              }
            ]
          },
          "execution_cmd": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"%TP_PLUGIN_FOLDER%aicommerce.ps1\" -Action last-video",
          "data": []
        },
        {
