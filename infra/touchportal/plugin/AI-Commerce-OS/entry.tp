          "data": []
        },
        {
          "id": "acmd_git_commit",
          "name": "Git Commit (add + status)",
          "prefix": "AI-Commerce",
          "type": "execute",
          "lines": {
            "action": [
              {
                "language": "default",
                "data": [
                  { "lineFormat": "git add -A && git status" }
                ]
              }
            ]
          },
          "execution_cmd": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"%TP_PLUGIN_FOLDER%aicommerce.ps1\" -Action git-commit",
