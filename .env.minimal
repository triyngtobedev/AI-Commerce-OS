# Minimal free-tier config — one YouTube Dark test video
# Uso: cp .env.minimal .env  &&  preencha as chaves abaixo
#
# Providers usados pelo scripts/test_one_video.py:
#   LLM     → Gemini (primário) + Groq (fallback)
#   Footage → Wikimedia (sem chave) + Pixabay (chave gratuita)
#   TTS     → Edge TTS (sem chave; Azure omitido de propósito)
# Pexels NÃO é necessário — cadeia YouTube Dark tenta Wikimedia → Pixabay → Pexels

# === LLM (precisa de pelo menos 1) ===
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# https://console.groq.com/keys
GROQ_API_KEY=

# === Footage (Pixabay gratuito; Wikimedia não exige chave) ===
# https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# === Plataforma / upload ===
DEFAULT_PLATFORM=youtube_dark
YOUTUBE_AUTO_UPLOAD=false

# === Sprint 30 (defaults seguros para teste local) ===
SPRINT30_ENABLED=true
SPRINT30_VISUAL_SCORE=true
SPRINT30_THUMBNAIL_AB=false
SPRINT30_AUDIO_LAYER=true
SPRINT30_RETENTION_CONTROLLER=true
SPRINT30_METRICS=true
