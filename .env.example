# Copie para .env e preencha as chaves

GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
PEXELS_API_KEY=

# Pixabay (fallback de mídia stock, gratuito)
PIXABAY_API_KEY=

# Hugging Face (gratuito) — imagens + vídeo fal.ai via Inference Providers
# Crie sua conta em huggingface.co e gere um token em:
# huggingface.co/settings/tokens (permissão: Inference Providers)
# Crédito free: US$ 0,10/mês (~1-2 vídeos Wan2.2)
HF_TOKEN=your_hf_token_here
HF_API_TOKEN=hf_...

# Replicate (secundário — Wan 2.6 T2V/I2V)
# replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...
# Modelo T2V (default: wan-video/wan-2.6-t2v) — ~$0,25/clip 5s 720p
REPLICATE_MODEL=wan-video/wan-2.6-t2v
REPLICATE_I2V_MODEL=wan-video/wan-2.6-i2v
REPLICATE_WAN_RESOLUTION=720p
REPLICATE_WAN_DURATION=5
# Imagem Flux Schnell no Replicate (~$0,003/img — template n8n dark)
# REPLICATE_FLUX_MODEL=black-forest-labs/flux-schnell
# Limite de cenas T2V pagas por vídeo (resto usa imagem + Ken Burns FFmpeg)
MAX_T2V_SCENES_PER_VIDEO=2
# Limite opcional de caracteres na narração (0 = desligado; template n8n usa ~2300)
# MAX_NARRATION_CHARS=2300
# NARRATION_CHAR_REWRITE_TARGET=2400
# Legenda karaoke palavra-a-palavra no ASS (estilo template n8n)
# SUBTITLE_KARAOKE=true

# fal.ai — Kling 2.6 Pro (OPCIONAL — requer crédito pago)
# Sem FAL_KEY: Kling Web (grátis) → Replicate Wan 2.6 → HF Wan2.2
# FAL_KEY=
# FAL_KLING_DURATION=5
# FAL_KLING_AUDIO=false

VIDEO_TIMEOUT=300

# Kling Web Playwright (tier grátis — 66 créditos/dia, tentado ANTES de APIs pagas)
KLING_EMAIL=seu@email.com
KLING_PASSWORD=suasenha
# KLING_DEBUG=true       # salva screenshots em debug/
# KLING_HEADFUL=true     # browser visível para debug manual
# KLING_SELECTOR_TIMEOUT=20000

# Configurações de geração de vídeo
VIDEO_OUTPUT_DIR=./output/videos
VIDEO_MAX_RETRIES=3
VIDEO_POLL_INTERVAL=10
VIDEO_TIMEOUT=300

# Modo de mídia: stock (padrão) | persona
CONTENT_MODE=stock

# Plataforma padrão: tiktok_shop | youtube_dark
DEFAULT_PLATFORM=tiktok_shop

# YouTube OAuth (upload automático + analytics)
# Configure com: python main.py --youtube-auth
# Documentação: docs/youtube_oauth.md
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Upload automático após produção (true/false)
# Alternativa à flag --upload na linha de comando
YOUTUBE_AUTO_UPLOAD=false

# Bloqueia upload mesmo com credenciais (true/false)
YOUTUBE_DRY_RUN=false

# Habilita/desabilita publicação globalmente (true/false)
YOUTUBE_PUBLISH_ENABLED=true

# Visibilidade do upload: private | unlisted | public
# Padrão seguro: unlisted (não listado — só quem tem o link vê)
UPLOAD_VISIBILITY=unlisted

# Azure Speech (TTS com SSML — motor principal de narração)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# --- Integração n8n (FastAPI + orquestrador de cenas) ---
# false = pipeline local inalterado; true = delega geração T2V de cenas ao n8n
USE_N8N_FOR_SCENES=false
# Tema injetado pelo n8n (não definir manualmente — gerenciado pelo pipeline_runner)
PIPELINE_TOPIC_OVERRIDE=
# Gere com: -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) })
PIPELINE_API_KEY=
PIPELINE_API_BASE_URL=http://127.0.0.1:8000
# URL que o n8n (Docker) usa para callback — no Windows com Docker Desktop:
N8N_CALLBACK_BASE_URL=http://host.docker.internal:8000
# Local: http://localhost:5678/webhook/scene-generation
# Produção: https://n8n.seudominio.com/webhook/scene-generation
N8N_SCENE_WEBHOOK_URL=
# Deve coincidir com N8N_WEBHOOK_SECRET em infra/.env.n8n
N8N_WEBHOOK_SECRET=

# --- Pipeline na nuvem (Railway.app — zero SSH) ---
# 1) Deploy: docs/deploy-railway.md
# 2) No PC local, configure URL + chave (mesma PIPELINE_API_KEY do Railway):
# CLOUD_API_URL=https://seu-app.up.railway.app
# CLOUD_API_KEY=<mesma PIPELINE_API_KEY do Railway>
CLOUD_API_URL=
CLOUD_API_KEY=
# Analytics — relatório semanal automático
# Sincronização roda no Railway; relatório salvo em reports/
REPORT_DAYS=7
